# App
PORT=3000
NODE_ENV=production

# Tracker sizing
TRACKER_MAX_HISTORY=50000
PAPER_RISK_USD=5
PAPER_MARGIN_PER_TRADE_USD=20
PAPER_LEVERAGE=5
PAPER_MAX_NOTIONAL_USD=100

# Binance execution defaults
PAPER_TRADING_ENABLED=false
BINANCE_EXECUTION_MODE=testnet
BINANCE_PAPER_API_KEY=
BINANCE_PAPER_API_SECRET=
BINANCE_PAPER_BASE_URL=https://testnet.binancefuture.com
BINANCE_PUBLIC_BASE_URL=https://fapi.binance.com

# Exchange throttling / caching
EXCHANGE_MARK_CACHE_TTL_MS=12000
EXCHANGE_CANDLE_CACHE_TTL_MS=120000
EXCHANGE_ORDER_LIMIT_10S=120
EXCHANGE_ORDER_MIN_GAP_MS=40
